# Copy to .env for local dev (optional — repo bundles the same ID as fallback)
# VITE_SITE_ORIGIN=https://solidified.dev
VITE_DISCORD_USER_ID=1220125293272891475
# VITE_DISCORD_LINK_HREF=https://discord.gg/your-invite
# Feedback proxy (Cloudflare Worker) — webhook is NOT in the frontend
# VITE_FEEDBACK_URL=https://solidified-feedback.your-subdomain.workers.dev
# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
# Omit to use Cloudflare test keys (always pass; not bot-safe in production).
# VITE_TURNSTILE_SITE_KEY=
# VITE_TURNSTILE_SECRET_KEY=
